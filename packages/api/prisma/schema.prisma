generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Family {
  id               String            @id @default(uuid())
  name             String
  timezone         String            @default("UTC")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          FamilyMember[]
  meals            Meal[]
  weekPlans        WeekPlan[]
  agentCredentials AgentCredential[]
}

model User {
  id          String           @id @default(uuid())
  email       String           @unique
  name        String
  avatarUrl   String?
  googleId    String?          @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  memberships FamilyMember[]
  suggestions MealSuggestion[]
}

model FamilyMember {
  id       String @id @default(uuid())
  role     Role   @default(CHILD)
  family   Family @relation(fields: [familyId], references: [id])
  familyId String
  user     User   @relation(fields: [userId], references: [id])
  userId   String

  @@unique([familyId, userId])
}

enum Role {
  PARENT
  CHILD
}

model Meal {
  id                   String           @id @default(uuid())
  name                 String
  description          String?
  imageUrl             String?
  placeholderKind      MealPlaceholderKind?
  difficulty           Difficulty?
  family               Family           @relation(fields: [familyId], references: [id])
  familyId             String
  ingredients          MealIngredient[]
  suggestions          MealSuggestion[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([familyId, placeholderKind])
}

enum MealPlaceholderKind {
  FREE_DAY
  LEFTOVERS
  TAKEOUT
  DINING_OUT
  TRAVEL
  SKIP
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model MealIngredient {
  id       String  @id @default(uuid())
  name     String
  quantity String?
  unit     String?
  category String?
  meal     Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  mealId   String
}

model WeekPlan {
  id        String    @id @default(uuid())
  weekStart DateTime
  family    Family    @relation(fields: [familyId], references: [id])
  familyId  String
  days      DayPlan[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([familyId, weekStart])
}

model DayPlan {
  id          String           @id @default(uuid())
  date        DateTime
  weekPlan    WeekPlan         @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  weekPlanId  String
  suggestions MealSuggestion[]

  @@unique([weekPlanId, date])
}

model MealSuggestion {
  id        String   @id @default(uuid())
  meal      Meal     @relation(fields: [mealId], references: [id])
  mealId    String
  dayPlan   DayPlan  @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)
  dayPlanId String
  suggestedBy User   @relation(fields: [userId], references: [id])
  userId    String
  approved  Boolean  @default(false)
  // Approver metadata. Approval is no longer actorless: when a suggestion is
  // approved we capture WHO approved it (a family member or an MCP agent
  // credential) and WHEN. `approvedByActorType` is "user" | "agent";
  // `approvedById` is the User.id or AgentCredential.id respectively. Left as
  // a plain string pair (not an FK) because the approver is polymorphic.
  approvedByActorType String?
  approvedById        String?
  approvedAt          DateTime?
  createdAt DateTime @default(now())
}

model GroceryList {
  id        String        @id @default(uuid())
  weekStart DateTime
  familyId  String
  items     GroceryItem[]
  createdAt DateTime      @default(now())
}

model GroceryItem {
  id            String      @id @default(uuid())
  name          String
  quantity      String?
  unit          String?
  category      String?
  checked       Boolean     @default(false)
  sources       String[]    @default([])
  groceryList   GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)
  groceryListId String
}

model ApiKey {
  id        String    @id @default(uuid())
  name      String
  key       String    @unique
  familyId  String
  createdBy String
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
}

/// Scoped, least-privilege credential for MCP agents that read AND mutate
/// meal plans. Deliberately SEPARATE from the read-only Magic Mirror `ApiKey`
/// so a write-capable agent credential can never be conflated with a display
/// key. Only the SHA-256 `hashedKey` is stored; the raw key is returned once
/// at creation/rotation and never persisted or logged. `scopes` holds the
/// per-operation grants (`meal_plan:read` | `meal_plan:schedule` |
/// `meal_plan:approve`). A credential is family-scoped, revocable
/// (`revokedAt`) and expirable (`expiresAt`).
model AgentCredential {
  id        String          @id @default(uuid())
  name      String
  hashedKey String          @unique
  family    Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  familyId  String
  scopes    String[]        @default([])
  createdBy String
  expiresAt DateTime?
  lastUsed  DateTime?
  revokedAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  auditLogs AgentAuditLog[]

  @@index([familyId])
}

/// Append-only audit trail for every agent authorization decision. Records
/// who (credential), what family, what action, the target resource id(s), the
/// outcome (allowed | denied) and an optional reason. `credentialId` is a
/// nullable FK with onDelete: SetNull so audit history survives credential
/// rotation/revocation/deletion. `familyId` is a plain string (matching the
/// existing `GroceryList.familyId` style) so the log is never cascade-wiped.
model AgentAuditLog {
  id           String           @id @default(uuid())
  actorType    String
  credential   AgentCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  credentialId String?
  familyId     String
  action       String
  targetType   String?
  targetIds    String[]         @default([])
  outcome      String
  reason       String?
  createdAt    DateTime         @default(now())

  @@index([familyId])
  @@index([credentialId])
}
