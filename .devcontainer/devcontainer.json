{
  "name": "Meal Planner",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest",
      "gatewayPorts": "no"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      }
    }
  },
  "postCreateCommand": "npm install -g pnpm@9 && pnpm install && pnpm db:generate",
  "postStartCommand": "bash .devcontainer/setup-sshd.sh",
  "forwardPorts": [2222, 3001, 5173, 5432],
  "portsAttributes": {
    "2222": { "label": "SSH" },
    "3001": { "label": "API" },
    "5173": { "label": "Frontend" },
    "5432": { "label": "PostgreSQL" }
  }
}
